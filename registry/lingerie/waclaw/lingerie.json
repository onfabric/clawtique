{
  "id": "waclaw",
  "name": "WhatsApp (waclaw)",
  "version": "1.0.0",
  "description": "WhatsApp channel plugin via waclaw proxy — shared across dresses that need WhatsApp messaging.",
  "plugins": [
    {
      "id": "waclaw",
      "spec": "@onfabric/waclaw-plugin",
      "setupNotes": [
        "You will need a connector token from the waclaw admin API"
      ]
    }
  ],
  "configSetup": {
    "configs": [
      { "key": "tools.media.audio.enabled", "value": true },
      {
        "key": "tools.media.audio.models",
        "value": "[{\"provider\":\"openai\",\"model\":\"gpt-4o-mini-transcribe\"}]"
      },
      { "key": "messages.tts.auto", "value": "tagged" },
      { "key": "messages.tts.provider", "value": "openai" }
    ],
    "configPrefix": "messages.tts.providers.openai",
    "properties": {
      "model": {
        "description": "OpenAI TTS model",
        "required": true,
        "default": "tts-1"
      },
      "voice": {
        "description": "OpenAI TTS voice",
        "required": true,
        "default": "nova"
      },
      "apiKey": {
        "description": "OpenAI API key for TTS",
        "required": true
      }
    }
  }
}
