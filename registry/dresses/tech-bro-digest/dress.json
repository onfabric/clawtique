{
  "id": "tech-bro-digest",
  "name": "Tech Bro Digest",
  "version": "1.0.0",
  "description": "Daily digest of tech news from configurable sources and topics.",

  "requires": {
    "lingerie": ["waclaw"]
  },

  "crons": [
    {
      "id": "tech-bro-digest",
      "name": "Tech digest",
      "skill": "tech-bro-digest",
      "defaults": { "time": "08:00" }
    }
  ],

  "skills": {
    "tech-bro-digest": {
      "name": "Tech digest",
      "description": "Searches configured news sources and compiles a morning digest of the most relevant stories.",
      "params": {
        "sources": {
          "description": "News sources to search (comma-separated)",
          "type": "string",
          "default": "Product Hunt, Hacker News"
        },
        "topics": {
          "description": "Topics to focus on (comma-separated)",
          "type": "string",
          "default": "AI agents, Startups"
        }
      }
    }
  }
}
